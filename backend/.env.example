# Amnezia WG Monitor Configuration Example

# SSH Connection Details
SSH_HOST=123.45.67.89
SSH_PORT=22
# It is highly recommended to use an unprivileged user restricted via sudo
SSH_USER=amnezia-monitor
SSH_PASSWORD=your_secure_password
# Alternatively, use SSH key for better security (leave password empty if using key)
# SSH_KEY_PATH=~/.ssh/id_rsa

# The name of your Amnezia Docker container (usually amnezia-awg or amnezia-wireguard)
DOCKER_CONTAINER=amnezia-awg

# Set to true to bypass SSH and use fake data for UI preview (useful for development)
MOCK_DATA=false

# Update interval in seconds (How often the backend polls the server)
# Recommended: 10 to 120 seconds.
UPDATE_INTERVAL_SECONDS=120
